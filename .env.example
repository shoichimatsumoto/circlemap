# DMM Webサービス API
# https://affiliate.dmm.com/api/ で取得
DMM_API_ID=your_api_id
# API呼び出し用（990〜997番台）
DMM_AFFILIATE_ID=your_affiliate_id-990
# 購入リンク用（サイト登録ID。CircleMapは005など）
DMM_LINK_AFFILIATE_ID=your_affiliate_id-005

# Supabase（Step 3 で設定）
# https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
# 同期バッチ用（サーバー側のみ・GitHubに上げない）
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# 同期API保護用（自分で決めた秘密の文字列）
SYNC_SECRET=your_random_secret_phrase
# Vercel Cron 用（Vercel が Bearer ヘッダーで送る。SYNC_SECRET と同じ値で OK）
CRON_SECRET=your_random_secret_phrase
